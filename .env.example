# Optional. Defaults to us-east-1 when unset.
AWS_REGION=us-east-1

# Required for chat (default provider). Create at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Optional. Use a named AWS profile instead of static credentials.
# AWS_PROFILE=default

# Optional. Set only if your Bedrock setup relies on bearer-token auth.
# AWS_BEARER_TOKEN_BEDROCK=

# Optional. Override the Pi agent resource directory.
# PI_AGENT_DIR=

# Optional. Keep Pi runtimes alive longer or shorter between chat turns.
# FLEET_PI_RUNTIME_TTL_MS=600000

# Optional. Server log verbosity.
# LOG_LEVEL=info

# ── Authentication (Better Auth + Neon) ──────────────────────────────
# Optional. Neon Postgres connection string (app role — DML only, no DDL).
# Leave unset for local SQLite at .fleet/auth.sqlite.
# FLEET_PI_AUTH_DATABASE_URL=

# Required for migrations only. Uses neondb_owner (full DDL privileges).
# Run migrations with: pnpm --filter web auth:migrate
# FLEET_PI_AUTH_MIGRATION_DATABASE_URL=

# ── Neon Managed Auth (fleet-pi-neon / jolly-lab-20094853) ────────────
# When NEON_AUTH_BASE_URL (or Vercel↔Neon NEON_AUTH_URL) is set, the app
# proxies auth to Neon Managed Auth instead of local Better Auth.
# Leave unset for local SQLite/anonymous chat.
# NEON_AUTH_BASE_URL=https://ep-calm-truth-aj2671iq.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth
# VITE_NEON_AUTH_URL=https://ep-calm-truth-aj2671iq.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth
# NEON_AUTH_JWKS_URL=https://ep-calm-truth-aj2671iq.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth/.well-known/jwks.json
# Cookie secret (≥32 chars). Falls back to BETTER_AUTH_SECRET when unset.
# NEON_AUTH_COOKIE_SECRET=
# Optional Neon Data API (not required for chat runtime / Pi mirror):
# NEON_DATA_API_URL=https://ep-calm-truth-aj2671iq.apirest.c-3.us-east-2.aws.neon.tech/neondb/rest/v1
# Vercel↔Neon integration also injects NEON_AUTH_URL (same as BASE_URL) —
# Fleet Pi accepts it as a fallback for NEON_AUTH_BASE_URL.

# Dual-host chat (Neon Function). Browser origin allowlist is required for CORS.
# FLEET_PI_CHAT_RUNTIME_CORS_ORIGINS=https://fleet-pi-web.vercel.app,http://localhost:3000
# Force auth on the chat runtime even without Vercel/Managed Auth markers:
# FLEET_PI_CHAT_RUNTIME_REQUIRE_AUTH=1
# VITE_FLEET_PI_CHAT_RUNTIME_URL=https://<neon-function-host>

# ── Chat session mirror (Pi JSONL + Neon) ────────────────────────────
# Optional. Neon Postgres connection string (app role — DML only, no DDL).
# Leave unset to keep Pi conversations only in .fleet/sessions JSONL and local
# SQLite provenance.
# FLEET_PI_CHAT_DATABASE_URL=

# Required for chat mirror migrations only. Use a direct owner connection.
# Run migrations with: pnpm --filter web chat:migrate
# FLEET_PI_CHAT_MIGRATION_DATABASE_URL=

# Required when auth is enabled. Generate with: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# Optional. Base URL used for OAuth callback URLs. Defaults to http://localhost:3000.
# BETTER_AUTH_URL=http://localhost:3000

# Optional. Path to the local auth SQLite database when Neon auth is unset.
# AUTH_DATABASE_PATH=

# Required to enable Daytona-backed authenticated workspaces.
# DAYTONA_API_KEY=

# Optional. Daytona API URL and target; the SDK default API URL is used when unset.
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=

# Optional. Shared secret expected in x-daytona-signature for Daytona webhooks.
# DAYTONA_WEBHOOK_SECRET=

# Optional. HTTPS repo URL used to sparse-seed agent-workspace into empty Daytona volumes.
# FLEET_PI_REPOSITORY_URL=https://github.com/Qredence/fleet-pi.git

# Optional. Google OAuth credentials. Google login is hidden when absent.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Product analytics (PostHog, client-side) ─────────────────────────
# Optional. Enables the chat funnel telemetry (chat_session_started,
# conversation_saved) and pageview capture from the browser. Leave unset to
# disable analytics entirely — capture calls become no-ops.
# VITE_PUBLIC_POSTHOG_KEY=
# Optional. Defaults to https://eu.i.posthog.com.
# VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
