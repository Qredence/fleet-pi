    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@openai/agents": "^0.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
