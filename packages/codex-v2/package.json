{
  "name": "codex-v2",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "bin": {
    "fleet-codex-v2": "./src/cli.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
