{
  "name": "fleet-pi",
  "version": "0.0.1",
  "private": true,
  "description": "A browser-based coding-agent workspace with Pi-backed chat, plan mode, and a durable agent-workspace.",
  "homepage": "https://github.com/Qredence/fleet-pi#readme",
  "bugs": {
    "url": "https://github.com/Qredence/fleet-pi/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Qredence/fleet-pi.git"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "turbo e2e",
    "prepare": "husky",
    "syncpack": "syncpack lint --dependency-types prod,dev,peer",
    "syncpack:fix": "syncpack fix --dependency-types prod,dev,peer",
    "syncpack:format": "syncpack format --dependency-types prod,dev,peer",
    "knip": "knip",
    "jscpd": "jscpd apps/web/src packages/ui/src",
    "tech-debt": "./scripts/scan-tech-debt.sh",
    "validate-agents-md": "node scripts/validate-agents-md.js",
    "generate:docs": "node scripts/generate-docs.js"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "diff": "^8.0.2",
    "typebox": "1.1.33",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.8.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^14.3.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "{apps,packages}/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter web exec eslint --fix"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "better-sqlite3",
      "esbuild",
      "koffi",
      "msw",
      "protobufjs",
      "unrs-resolver"
    ]
  }
}
