{
  "name": "fleet-pi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "prepare": "husky",
    "syncpack": "syncpack lint --dependency-types prod,dev,peer",
    "syncpack:fix": "syncpack fix --dependency-types prod,dev,peer",
    "syncpack:format": "syncpack format --dependency-types prod,dev,peer",
    "knip": "knip",
    "jscpd": "jscpd apps/web/src packages/ui/src",
    "tech-debt": "./scripts/scan-tech-debt.sh"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "{apps,packages}/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.8.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^14.3.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.6"
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "flatted": ">=3.4.2",
      "lodash": ">=4.18.0",
      "undici": ">=7.24.0",
      "h3": ">=2.0.1-rc.17",
      "@tanstack/start-server-core>h3": ">=2.0.1-rc.17"
    }
  }
}
