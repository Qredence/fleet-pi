{
  "name": "fleet-pi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "turbo e2e",
    "prepare": "husky",
    "syncpack": "syncpack lint --dependency-types prod,dev,peer",
    "syncpack:fix": "syncpack fix --dependency-types prod,dev,peer",
    "syncpack:format": "syncpack format --dependency-types prod,dev,peer",
    "knip": "knip",
    "jscpd": "jscpd apps/web/src packages/ui/src",
    "tech-debt": "./scripts/scan-tech-debt.sh",
    "validate-agents-md": "node scripts/validate-agents-md.js",
    "generate:docs": "node scripts/generate-docs.js",
    "symphony:validate": "zsh ./scripts/symphony/validate-workflow.zsh",
    "symphony:run": "zsh ./scripts/symphony/run-service.zsh",
    "symphony:test-plugin": "zsh ./scripts/symphony/test-plugin.zsh",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:build": "pnpm --filter web build && pnpm --filter desktop build",
    "desktop:pack": "pnpm run desktop:build && pnpm --filter desktop run pack",
    "desktop:dist": "pnpm run desktop:build && pnpm --filter desktop run dist"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "{apps,packages}/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.8.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^14.3.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-tui": "^0.70.6",
    "diff": "^5.2.0",
    "typebox": "1.1.33"
  },
  "pnpm": {
    "overrides": {
      "@anthropic-ai/sdk": ">=0.91.1",
      "handlebars": ">=4.7.9",
      "flatted": ">=3.4.2",
      "lodash": ">=4.18.0",
      "undici": ">=7.24.0",
      "h3": ">=2.0.1-rc.17",
      "@tanstack/start-server-core>h3": ">=2.0.1-rc.17"
    }
  }
}
