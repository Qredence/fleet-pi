{
  "packages": [
    "npm:pi-autoresearch",
    "npm:pi-skill-palette",
    "npm:pi-autocontext",
    "npm:pi-web-access",
    "npm:@daytona/pi"
  ],
  "skills": [
    "../agent-workspace/pi/skills",
    "npm:pi-autoresearch",
    "npm:pi-autocontext"
  ],
  "prompts": [
    "../agent-workspace/pi/prompts",
    "npm:pi-autocontext",
    "workspace"
  ],
  "extensions": [
    "extensions/bedrock-bearer-auth",
    "extensions/resource-install",
    "extensions/daytona-sandbox",
    "extensions/vendor/filechanges",
    "extensions/vendor/subagents",
    "../agent-workspace/pi/extensions/enabled",
    "npm:@evo-hq/pi-evo",
    "local",
    "npm:pi-autoresearch",
    "npm:pi-web-access"
  ],
  "defaultProvider": "openai",
  "defaultModel": "deepseek-v4-flash-free",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "github-copilot/*",
    "openai-chat-completions/deepseek-v4-flash-free"
  ],
  "enableSkillCommands": true,
  "themes": []
}
