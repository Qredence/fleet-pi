{
  "$schema": "https://unpkg.com/syncpack@14.3.1/dist/schema.json",
  "versionGroups": [
    {
      "label": "Workspace dependencies use workspace protocol",
      "dependencies": ["$LOCAL"],
      "dependencyTypes": ["dev", "prod"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Ignore tag-based versions",
      "dependencies": ["nitro"],
      "isIgnored": true
    }
  ]
}
