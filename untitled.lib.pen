                                    },
                                    {
                                      "type": "frame",
                                      "id": "l9a32U",
                                      "name": "h2",
                                      "width": "fill_container",
                                      "stroke": {
                                        "align": "inside",
                                        "thickness": 1
                                      },
                                      "layout": "vertical",
                                      "padding": [
                                        23,
                                        0,
                                        0,
                                        0
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "GGR5l",
                                          "name": "Source and tool usage",
                                          "fill": "#131313ff",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Source and tool usage",
                                          "lineHeight": 1.222083330154419,
                                          "textAlignVertical": "middle",
                                          "fontFamily": "SF Pro Text",
                                          "fontSize": 24,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "JRA3W",
                                          "name": "sourceBody",
                                          "fill": "#404040",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Prefer primary sources: user-shared research docs, design files, and recorded sessions. When referencing external frameworks or heuristics, cite them briefly. Avoid fabricating data points — if evidence is thin, say so and recommend how to fill the gap.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 16,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "GNw0p",
                                      "name": "h2",
                                      "width": "fill_container",
                                      "stroke": {
                                        "align": "inside",
                                        "thickness": 1
                                      },
                                      "layout": "vertical",
                                      "padding": [
                                        23,
                                        0,
                                        0,
                                        0
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "xHs8K",
                                          "name": "Memory",
                                          "fill": "#131313ff",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Memory",
                                          "lineHeight": 1.222083330154419,
                                          "textAlignVertical": "middle",
                                          "fontFamily": "SF Pro Text",
                                          "fontSize": 24,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "XnjsL",
                                          "name": "memBody",
                                          "fill": "#404040",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Carry context across turns within a session. When the conversation references earlier artifacts or decisions, connect them explicitly. At the end of an audit or synthesis, offer a one-paragraph recap that can serve as a handoff note.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 16,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
