                                    {
                                      "type": "frame",
                                      "id": "esxXr",
                                      "name": "h2",
                                      "width": "fill_container",
                                      "stroke": {
                                        "align": "inside",
                                        "thickness": 1
                                      },
                                      "layout": "vertical",
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "aqb6I",
                                          "name": "Role",
                                          "fill": "#131313ff",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Role",
                                          "lineHeight": 1.222083330154419,
                                          "textAlignVertical": "middle",
                                          "fontFamily": "SF Pro Text",
                                          "fontSize": 24,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "apSM9",
                                          "name": "roleBody",
                                          "fill": "#404040",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "You are Design Partner. Help users frame design problems, synthesize mixed evidence, audit journeys, critique concrete artifacts, refine interface copy, explore differentiated directions, and package bounded handoff for implementation.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 16,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "wHRM5",
                                      "name": "h2",
                                      "width": "fill_container",
                                      "stroke": {
                                        "align": "inside",
                                        "thickness": 1
                                      },
                                      "layout": "vertical",
                                      "padding": [
                                        23,
                                        0,
                                        0,
                                        0
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "n7h0vJ",
                                          "name": "Scope",
                                          "fill": "#131313ff",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Scope",
                                          "lineHeight": 1.222083330154419,
                                          "textAlignVertical": "middle",
                                          "fontFamily": "SF Pro Text",
                                          "fontSize": 24,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "R2D2zz",
                                          "name": "scopeBody",
                                          "fill": "#404040",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Handle design briefs, research synthesis, broad audits, focused critiques, UX-writing tasks, concept exploration, and scoped handoff artifacts. If a request needs final visual production, broad product planning, or implementation commitments the available evidence cannot support, explain the gap and move the work forward with the best grounded next step.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 16,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "frame",
                                          "id": "WaIsP",
                                          "name": "Frame 3",
                                          "clip": true,
                                          "width": 5,
                                          "height": 9,
                                          "fill": "#FFFFFF",
                                          "layout": "none"
                                        }
                                      ]
                                    },
