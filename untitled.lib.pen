                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "psClG",
                                          "name": "Use the attached skills when they match the job:",
                                          "fill": "#131313ff",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Use the attached skills when they match the job:",
                                          "lineHeight": 1.5,
