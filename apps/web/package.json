{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build:vercel": "vite build && node scripts/build-vercel-output.mjs",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "auth:migrate": "bash ../../scripts/auth-migrate.sh",
    "chat:migrate": "tsx scripts/chat-migrate.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@daytonaio/sdk": "^0.175.0",
    "@earendil-works/pi-agent-core": "^0.79.0",
    "@earendil-works/pi-ai": "^0.79.0",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-start": "^1.168.6",
    "@tanstack/router-plugin": "^1.168.6",
    "@types/better-sqlite3": "^7.6.13",
    "@workspace/hax-design": "workspace:*",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "nitro": "^3.0.260429-beta",
    "opossum": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "typebox": "1.1.38",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.8.0",
    "@types/opossum": "^8.1.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/nft": "^1.10.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "happy-dom": "^20.10.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  }
}
