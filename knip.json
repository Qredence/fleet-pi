{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["eslint.config.js", ".pi/extensions/**/*.ts"],
      "ignoreBinaries": ["bash", "eslint", "zsh"]
    },
    "apps/desktop": {
      "entry": ["src/preload.ts", "src/**/*.test.ts"]
    },
    "apps/web": {
      "entry": [
        "scripts/**/*.ts",
        "src/router.tsx",
        "src/routes/__root.tsx",
        "src/routes/**/*.tsx",
        "src/routes/api/**/*.ts",
        "src/lib/**/*.test.ts",
        "src/lib/**/*.spec.ts"
      ],
      "ignoreDependencies": [
        "nitro",
        "@tanstack/router-plugin",
        "tailwindcss",
        "pino-pretty",
        "@apidevtools/swagger-cli"
      ]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"]
    }
  }
}
