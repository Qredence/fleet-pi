{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": [
        "eslint.config.js",
        ".pi/extensions/**/*.ts",
        "neon.ts",
        "functions/**/*.ts"
      ],
      "project": [
        "scripts/**/*.js",
        ".pi/extensions/**/*.ts",
        "functions/**/*.ts",
        "!agent-workspace/pi/**"
      ],
      "ignoreDependencies": [
        "zod",
        "@aws-sdk/client-s3",
        "@neondatabase/serverless"
      ]
    },
    "apps/web": {
      "entry": [
        "scripts/**/*.ts",
        "src/router.tsx",
        "src/routes/__root.tsx",
        "src/routes/**/*.tsx",
        "src/routes/api/**/*.ts",
        "src/lib/pi/chat-runtime/router.ts",
        "src/lib/**/*.test.ts",
        "src/lib/**/*.spec.ts"
      ],
      "ignoreDependencies": [
        "nitro",
        "@tanstack/router-plugin",
        "tailwindcss",
        "pino-pretty",
        "tslib"
      ]
    },
    "packages/hax-design": {
      "entry": ["src/**/*.tsx", "src/**/*.ts", "scripts/**/*.ts"]
    }
  }
}
